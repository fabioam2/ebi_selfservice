# ================================================================
# .htaccess — Proteção da pasta assets/signing/
# Bloqueia acesso direto via URL à chave privada e ao certificado
# ================================================================

# Bloqueia acesso à chave privada
<Files "private-key.pem">
    Require all denied
</Files>

# Permitir acesso ao certificado público (necessário para QZ Tray via fetch/AJAX)
<Files "digital-certificate.txt">
    Require all granted
</Files>

# Apenas sign-message.php pode ser chamado externamente
<FilesMatch "^(?!sign-message\.php$).*\.php$">
    Require all denied
</FilesMatch>
